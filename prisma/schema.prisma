}

/// 플랫폼 관리자 활동 감사 로그
model PlatformAuditLog {
  id         Int      @id @default(autoincrement())
  actorId    String   @map("actor_id") @db.VarChar(36)
  actorName  String   @map("actor_name") @db.VarChar(255)
  action     String   @db.VarChar(100)
  targetType String   @map("target_type") @db.VarChar(50)
  targetId   String   @map("target_id") @db.VarChar(50)
  targetName String?  @map("target_name") @db.VarChar(255)
  detail     String?  @db.Text
  ipAddress  String?  @map("ip_address") @db.VarChar(50)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([targetType, targetId])
  @@index([createdAt(sort: Desc)])
  @@map("platform_audit_logs")
}

/// 공지사항
model Notice {
  id          Int       @id @default(autoincrement())
  title       String    @db.VarChar(300)
  content     String    @db.Text
  category    String    @default("general") @db.VarChar(50) // general, update, maintenance
  isPinned    Boolean   @default(false) @map("is_pinned")
  isPublished Boolean   @default(false) @map("is_published")
  authorId    String    @map("author_id") @db.VarChar(36)
  authorName  String    @map("author_name") @db.VarChar(255)
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")

  @@index([isPublished, createdAt(sort: Desc)])
  @@map("notices")
}

/// 고객 문의
model SupportTicket {
  id             Int      @id @default(autoincrement())
  subject        String   @db.VarChar(300)
  content        String   @db.Text
  category       String   @default("general") @db.VarChar(50) // general, bug, feature, billing
  status         String   @default("open") @db.VarChar(30) // open, in_progress, resolved, closed
  priority       String   @default("normal") @db.VarChar(30) // low, normal, high, urgent
  requesterId    String   @map("requester_id") @db.VarChar(36)
  requesterName  String   @map("requester_name") @db.VarChar(255)
  requesterEmail String?  @map("requester_email") @db.VarChar(255)
  organizationId Int?     @map("organization_id")
  assigneeId     String?  @map("assignee_id") @db.VarChar(36)
  assigneeName   String?  @map("assignee_name") @db.VarChar(255)
  reply          String?  @db.Text
  repliedAt      DateTime? @map("replied_at")
  resolvedAt     DateTime? @map("resolved_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([status, createdAt(sort: Desc)])
  @@map("support_tickets")
}

/// 구독/요금제 플랜
model SubscriptionPlan {
  id            Int      @id @default(autoincrement())
  code          String   @unique @db.VarChar(50) // free, starter, professional, enterprise
  name          String   @db.VarChar(100)
  description   String?  @db.VarChar(500)
  monthlyPrice  Int      @default(0) @map("monthly_price")
  maxUsers      Int      @default(5) @map("max_users")
  maxWorksites  Int      @default(1) @map("max_worksites")
  features      String?  @db.Text // JSON: ["scope1","scope2","scope3","report","ai"]
  isActive      Boolean  @default(true) @map("is_active")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  subscriptions OrgSubscription[]

  @@map("subscription_plans")
}

/// 기업별 구독 상태
model OrgSubscription {
  id             Int       @id @default(autoincrement())
  organizationId Int       @map("organization_id")
  planId         Int       @map("plan_id")
  status         String    @default("active") @db.VarChar(30) // active, expired, cancelled
  startDate      DateTime  @map("start_date") @db.Date
  endDate        DateTime? @map("end_date") @db.Date
  memo           String?   @db.VarChar(500)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at")

  plan           SubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([organizationId])
  @@map("org_subscriptions")
}

/// 챗봇 설정
model ChatbotConfig {
  id              Int      @id @default(autoincrement())
  projectId       String   @unique @map("project_id") @db.VarChar(100)
  botName         String   @default("ESG_On 어시스턴트") @map("bot_name") @db.VarChar(200)
  theme           String   @default("light") @db.VarChar(20) // light, dark
  placeholder     String?  @db.VarChar(500)
  welcomeMessage  String?  @map("welcome_message") @db.Text
  ragNamespace    String?  @map("rag_namespace") @db.VarChar(200)
  chatApiUrl      String?  @map("chat_api_url") @db.VarChar(500)
  confirmApiUrl   String?  @map("confirm_api_url") @db.VarChar(500)
  isEnabled       Boolean  @default(false) @map("is_enabled")
  position        String   @default("bottom-right") @db.VarChar(30) // bottom-right, bottom-left
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("chatbot_configs")
}

/// 공통 코드 마스터 (단위, 연료 종류, 에너지 유형 등)
model CommonCode {
  id          Int      @id @default(autoincrement())
  codeGroup   String   @map("code_group") @db.VarChar(50)
  code        String   @db.VarChar(100)
  name        String   @db.VarChar(200)
  description String?  @db.VarChar(500)
  sortOrder   Int      @default(0) @map("sort_order")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([codeGroup, code], name: "uq_common_code")
  @@map("common_codes")
}

/// 외부 API 연동 소스 설정
model IntegrationSource {
  id             Int              @id @default(autoincrement())
  organizationId Int?             @map("organization_id")
  name           String           @db.VarChar(100)
  sourceType     String           @map("source_type") @db.VarChar(50) // kepco, district_heat, emission_engine, supplier_portal, custom
  scope        Int?             // 1, 2, 3 or null (multi-scope)
  endpoint     String?          @db.VarChar(500)
  authType     String           @default("api_key") @map("auth_type") @db.VarChar(30) // api_key, oauth2, basic, none
  authConfig   String?          @map("auth_config") @db.Text // encrypted JSON: { apiKey, clientId, clientSecret, ... }
  fieldMapping String?          @map("field_mapping") @db.Text // JSON: { remote_field: local_field }
  syncInterval Int?             @map("sync_interval") // minutes, null = manual only
  isActive     Boolean          @default(true) @map("is_active")
  lastSyncAt   DateTime?        @map("last_sync_at")
  lastSyncStatus String?        @map("last_sync_status") @db.VarChar(20) // success, error, partial
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @default(now()) @updatedAt @map("updated_at")
  syncLogs     IntegrationSyncLog[]
  organization Organization?       @relation(fields: [organizationId], references: [id])

  @@map("integration_sources")
}

/// API 동기화 실행 로그
model IntegrationSyncLog {
  id           Int              @id @default(autoincrement())
  sourceId     Int              @map("source_id")
  source       IntegrationSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  status       String           @db.VarChar(20) // success, error, partial
  recordsTotal Int              @default(0) @map("records_total")
  recordsSaved Int              @default(0) @map("records_saved")
  recordsFailed Int             @default(0) @map("records_failed")
  errorMessage String?          @map("error_message") @db.Text
  detail       String?          @db.Text // JSON: synced facility IDs, months, etc.
  durationMs   Int?             @map("duration_ms")
  startedAt    DateTime         @default(now()) @map("started_at")
  completedAt  DateTime?        @map("completed_at")

  @@index([sourceId, startedAt(sort: Desc)])
  @@map("integration_sync_logs")
}
